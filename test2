local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"
local HubName = "RLWSCRIPTS"

-- =============================================
--  HÀM GỬI WEBHOOK (MÀU SẮC THEO SKIN)
