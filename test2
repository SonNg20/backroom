-- Tạo UI hiển thị số boss
local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Tạo Frame chính
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BossCounterUI"
screenGui.Parent = playerGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 200, 0, 50)
mainFrame.Position = UDim2.new(1, -220, 0, 10) -- Góc phải trên
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BackgroundTransparency = 0.2
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

-- Thêm hiệu ứng bo góc
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

-- Label hiển thị số boss
local bossLabel = Instance.new("TextLabel")
bossLabel.Size = UDim2.new(1, 0, 1, 0)
bossLabel.BackgroundTransparency = 1
bossLabel.Text = "🔄 Đang quét..."
bossLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
bossLabel.TextScaled = true
bossLabel.Font = Enum.Font.GothamBold
bossLabel.Parent = mainFrame

-- Hàm quét và cập nhật UI
local function scanBosses()
    local Breakables = workspace.__THINGS.Breakables
    local bosses = 0
    
    for _, breakable in ipairs(Breakables:GetChildren()) do
        if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
            bosses += 1
        end
    end
    
    -- Cập nhật UI
    if bosses >= 3 then
        bossLabel.Text = string.format("⚠️ %d Bosses phát hiện!", bosses)
        bossLabel.TextColor3 = Color3.fromRGB(255, 50, 50) -- Màu đỏ cảnh báo
        print("3 or more bosses detected:", bosses)
    else
        bossLabel.Text = string.format("👾 Số Boss: %d", bosses)
        bossLabel.TextColor3 = Color3.fromRGB(100, 255, 100) -- Màu xanh
    end
    
    return bosses
end

-- Quét lần đầu
scanBosses()

-- Tự động cập nhật khi có thay đổi trong Breakables
local connection
connection = Breakables.ChildAdded:Connect(function()
    scanBosses()
end)

-- Thêm cả khi child bị xóa
local function onChildRemoved()
    scanBosses()
end

-- Lưu ý: Roblox không có sẵn ChildRemoved cho Instance, 
-- nhưng có thể dùng DescendantRemoving hoặc loop check
-- Cách đơn giản: Dùng timer check mỗi giây
game:GetService("RunService").Heartbeat:Connect(function()
    -- Check mỗi 1 giây để tiết kiệm performance
    if tick() % 1 < 0.1 then
        scanBosses()
    end
end)

-- Nếu muốn tối ưu hơn, có thể dùng signal khi Breakables thay đổi
-- Tạo hàm hủy khi cần
local function cleanup()
    if connection then
        connection:Disconnect()
    end
    screenGui:Destroy()
end

-- Tự động cleanup khi game kết thúc
game:GetService("Players").LocalPlayer.OnTeleport:Connect(cleanup)
