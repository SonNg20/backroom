print("START HOOK")
print("Hay no 1 qua trung bat ky de xem du lieu!")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Network = ReplicatedStorage:WaitForChild("Network", 10)

local eventsToHook = {
    "CustomEggs_Hatch",
    "VL_Hatch", 
    "Exclusive Eggs: Open",
    "Hatch"
}

local hookedCount = 0

local function inspectData(data, depth)
    depth = depth or 0
    local prefix = string.rep("  ", depth)
    
    if type(data) == "table" then
        for k, v in pairs(data) do
            if type(v) == "table" then
                print(prefix .. tostring(k) .. " = (Table)")
                inspectData(v, depth + 1)
            else
                print(prefix .. tostring(k) .. " = " .. tostring(v))
            end
        end
    else
        print(prefix .. tostring(data))
    end
end

for _, evName in ipairs(eventsToHook) do
    local ev = Network:FindFirstChild(evName)
    if ev then
        ev.OnClientEvent:Connect(function(...)
            print("=============================")
            print("BAT DUOC EVENT: " .. evName)
            local args = {...}
            for i, arg in ipairs(args) do
                print("--- ARGUMENT " .. i .. " ---")
                inspectData(arg)
            end
            print("=============================")
        end)
        hookedCount = hookedCount + 1
        print("Da Hook vao: " .. evName)
    end
end

print("Da hook xong " .. hookedCount .. " su kien. Hay no trung di!")
