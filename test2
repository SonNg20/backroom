-- ============================
-- HOP SERVER KHÔNG TRÙNG
-- ============================

if not game:IsLoaded() then game.Loaded:Wait() end

local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local PLACE_ID = 8737899170

-- Lưu server đã ghé
if not getgenv().VisitedServers then
    getgenv().VisitedServers = {}
end

-- Lưu server hiện tại
getgenv().VisitedServers[game.JobId] = true

local function findNewServer()
    local allServers = {}
    
    -- Lấy 200 server
    for page = 1, 2 do
        local sortOrder = page == 1 and "Desc" or "Asc"
        local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?limit=100&sortOrder=" .. sortOrder
        
        local success, result = pcall(function()
            return game:HttpGet(url)
        end)
        
        if success and result then
            local data = HttpService:JSONDecode(result)
            if data.data then
                for _, server in ipairs(data.data) do
                    table.insert(allServers, server)
                end
            end
        end
    end
    
    -- Trộn ngẫu nhiên
    for i = #allServers, 2, -1 do
        local j = math.random(1, i)
        allServers[i], allServers[j] = allServers[j], allServers[i]
    end
    
    -- Tìm server chưa ghé, ít người
    for _, server in ipairs(allServers) do
        local jobId = server.id
        local playing = server.playing
        local maxPlayers = server.maxPlayers
        
        if not getgenv().VisitedServers[jobId] and playing < maxPlayers then
            return server
        end
    end
    
    -- Reset nếu hết server mới
    getgenv().VisitedServers = {[game.JobId] = true}
    for _, server in ipairs(allServers) do
        if server.playing < server.maxPlayers then
            return server
        end
    end
    
    return nil
end

local bestServer = findNewServer()

if bestServer then
    getgenv().VisitedServers[bestServer.id] = true
    pcall(function()
        TeleportService:TeleportToPlaceInstance(PLACE_ID, bestServer.id, player)
    end)
else
    pcall(function()
        TeleportService:Teleport(PLACE_ID)
    end)
end
