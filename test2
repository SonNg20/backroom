-- ============================
-- AUTO JOIN EVENT + QUÉT BOSS + HIỂN THỊ UI
-- ============================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ============================
-- GUI
-- ============================
if game.CoreGui:FindFirstChild("BossScanner") then game.CoreGui.BossScanner:Destroy() end
local sg = Instance.new("ScreenGui", game.CoreGui)
sg.Name = "BossScanner"

local label = Instance.new("TextLabel", sg)
label.Size = UDim2.new(0, 250, 0, 100)
label.Position = UDim2.new(0, 10, 0, 10)
label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
label.BackgroundTransparency = 0.3
label.TextColor3 = Color3.fromRGB(0, 255, 100)
label.Font = Enum.Font.Code
label.TextSize = 12
label.TextWrapped = true
label.Text = "Dang vao event..."

-- ============================
-- AUTO JOIN EVENT
-- ============================
local libraryFolder = ReplicatedStorage:WaitForChild("Library", 30)
if libraryFolder then
    local ClientFolder = libraryFolder:WaitForChild("Client", 15)
    local InstancingCmds = require(ClientFolder:WaitForChild("InstancingCmds"))
    local FFlags = require(ClientFolder:WaitForChild("FFlags"))
    
    local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
    if joinTarget then
        InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
    end
end

-- ============================
-- ĐẾM BOSS & HIỂN THỊ LIÊN TỤC
-- ============================
task_spawn(function()
    -- Đợi event load
    for i = 10, 1, -1 do
        label.Text = "Dang vao event... (" .. i .. "s)"
        task.wait(1)
    end
    
    -- Quét boss liên tục
    while task.wait(1) do
        local Breakables = workspace.__THINGS.Breakables
        local bosses = 0
        
        for _, breakable in ipairs(Breakables:GetChildren()) do
            if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
                bosses = bosses + 1
            end
        end
        
        local str = "🔍 Boss Scanner\n"
        str = str .. "-------------------\n"
        str = str .. "Số Boss: " .. bosses .. "\n"
        str = str .. "Server: " .. game.JobId .. "\n"
        
        if bosses >= 3 then
            str = str .. "🔥 SERVER NHIEU BOSS!"
        else
            str = str .. "Đang tìm..."
        end
        
        label.Text = str
    end
end)
