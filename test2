local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"
local HubName = "SonNg" -- Bạn muốn tên gì ở dòng dưới cùng thì đổi chỗ này

-- =============================================
--  HÀM GỬI WEBHOOK (FORMAT GIỐNG ẢNH)
-- =============================================
local HttpService = game:GetService("HttpService")
local reqFunc = syn and syn.request or (http and http.request) or request

local function sendToDiscord(petName)
    local playerName = game.Players.LocalPlayer.Name
    local currentTime = os.date("%H:%M:%S") -- Lấy giờ phút giây hiện tại
    
    -- Tạo cấu trúc tin nhắn y hệt ảnh
    local data = {
        ["embeds"] = {{
            ["title"] = "🐣 NEW PET HATCHED! 🎉",
            ["color"] = 5763719, -- Màu xanh lá (giống các tin nhắn pet thường)
            ["fields"] = {
                {
                    ["name"] = "**Pet:**",
                    ["value"] = "**" .. petName .. "**",
                    ["inline"] = false -- Để xuống dòng cho đẹp
                },
                {
                    ["name"] = "**User:**",
                    ["value"] = "**" .. playerName .. "**",
                    ["inline"] = true
                },
                {
                    ["name"] = "**Time:**",
                    ["value"] = "```" .. currentTime .. "```", -- Dùng khung code để giống ảnh
                    ["inline"] = true
                }
            },
            ["footer"] = { 
                ["text"] = "powered by " .. HubName .. " - Hôm nay lúc " .. currentTime
            }
        }}
    }

    pcall(function()
        reqFunc({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    print("✅ Đã gửi thông báo pet: " .. petName)
end

-- =============================================
--  CỐT LÕI: LẤY DỮ LIỆU TỪ GAME
-- =============================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveModule

local ok, mod = pcall(function()
    return require(ReplicatedStorage.Library.Client.Save)
end)
if ok then SaveModule = mod end

if not SaveModule then
    warn("❌ Lỗi: Không tìm thấy module Save.")
    return
end

local previousPetCounts = {}
local firstRun = true

print("🟢 Đang tải dữ liệu Pet hiện tại...")

local function checkForNewPet()
    local currentPetCounts = {}
    
    local success, data = pcall(function() return SaveModule.Get() end)
    if not success or not data or not data.Inventory or not data.Inventory.Pet then
        return 
    end

    -- Đếm số lượng từng loại Pet trong Inventory
    for _, petData in pairs(data.Inventory.Pet) do
        if petData.id then
            local name = petData.id
            local amount = petData._am or 1
            currentPetCounts[name] = (currentPetCounts[name] or 0) + amount
        end
    end

    -- Lần chạy đầu tiên: Chỉ ghi nhận số liệu
    if firstRun then
        previousPetCounts = currentPetCounts
        firstRun = false
        print("✅ Đã lưu dữ liệu Pet. Bắt đầu theo dõi MỌI Pet...")
        return
    end

    -- So sánh sự thay đổi
    for petName, currentCount in pairs(currentPetCounts) do
        local prevCount = previousPetCounts[petName] or 0
        
        -- Nếu số lượng tăng lên => Có pet mới (Không lọc gì cả)
        if currentCount > prevCount then
            sendToDiscord(petName)
        end
    end

    -- Cập nhật danh sách cũ
    previousPetCounts = currentPetCounts
end

-- =============================================
--  VÒNG LẶP CHẠY
-- =============================================
task.spawn(function()
    while true do
        pcall(checkForNewPet)
        task.wait(3) -- Cứ 3 giây check 1 lần
    end
end)

print("🟢 Script đã chạy xong! Nở trứng là Discord báo y hệt ảnh.")
