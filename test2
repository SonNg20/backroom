local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"
local HubName = "RLWSCRIPTS"

-- =============================================
--  HÀM GỬI WEBHOOK
-- =============================================
local HttpService = game:GetService("HttpService")
local reqFunc = syn and syn.request or (http and http.request) or request

local function sendToDiscord(petName, totalCount, petType, color)
    local playerName = game.Players.LocalPlayer.Name
    local currentTime = os.date("%H:%M:%S")
    
    local titles = {
        Titanic = "💎 TITANIC PET CAUGHT! ✨",
        Golden = "✨ GOLDEN HUGE CAUGHT! ✨",
        Rainbow = "🌈 RAINBOW HUGE CAUGHT! 🌈",
        Huge = "🎉 HUGE PET CAUGHT! 🔥"
    }
    
    local data = {
        ["embeds"] = {{
            ["title"] = titles[petType] or "🎉 HUGE PET CAUGHT! 🔥",
            ["color"] = color,
            ["fields"] = {
                { ["name"] = "🐾 **Pet:**", ["value"] = "**" .. petName .. "**", ["inline"] = true },
                { ["name"] = "👤 **User:**", ["value"] = "||**" .. playerName .. "**||", ["inline"] = true },
                { ["name"] = "⏰ **Time:**", ["value"] = "`" .. currentTime .. "`", ["inline"] = true },
                { ["name"] = "📦 **Total:**", ["value"] = "`" .. tostring(totalCount) .. "`", ["inline"] = true }
            },
            ["footer"] = { ["text"] = "⚡ powered by " .. HubName .. " - " .. os.date("%H:%M ngày %d/%m") }
        }}
    }

    pcall(function()
        reqFunc({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    print("✅ Đã gửi " .. petType .. ": " .. petName)
end

-- =============================================
--  LẤY DỮ LIỆU GAME & PHÂN LOẠI PET (BẢN NÂNG CẤP)
-- =============================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveModule

local ok, mod = pcall(function()
    return require(ReplicatedStorage.Library.Client.Save)
end)
if ok then SaveModule = mod end

if not SaveModule then
    warn("❌ Lỗi: Không tìm thấy module Save.")
    return
end

local previousPetCounts = {}
local firstRun = true

print("🟢 Đang tải dữ liệu Pet hiện tại...")

local function classifyPet(name)
    if not name then return nil, nil end
    local lower = name:lower()
    
    -- 1. Kiểm tra Titanic trước
    if lower:find("titanic") then
        return "Titanic", 9699539 -- Tím
    end
    
    -- 2. Kiểm tra MÀU SẮC đặc trưng trước
    local isGolden = lower:find("golden")
    local isRainbow = lower:find("rainbow")
    local isHuge = lower:find("huge")
    
    -- Nếu có màu sắc + Huge => Trả về đúng loại
    if isGolden and isHuge then
        return "Golden", 16766720 -- Vàng
    end
    
    if isRainbow and isHuge then
        return "Rainbow", 16711935 -- Hồng
    end
    
    -- 3. Nếu không có màu sắc nhưng có Huge (Huge thường)
    if isHuge then
        return "Huge", 16753920 -- Cam
    end
    
    return nil, nil
end

local function checkForNewPet()
    local currentPetCounts = {}
    
    local success, data = pcall(function() return SaveModule.Get() end)
    if not success or not data or not data.Inventory or not data.Inventory.Pet then
        return 
    end

    for _, petData in pairs(data.Inventory.Pet) do
        if petData.id then
            local name = petData.id
            local amount = petData._am or 1
            currentPetCounts[name] = (currentPetCounts[name] or 0) + amount
        end
    end

    if firstRun then
        previousPetCounts = currentPetCounts
        firstRun = false
        print("✅ Đã lưu dữ liệu Pet. Chỉ theo dõi Huge/Titanic...")
        return
    end

    for petName, currentCount in pairs(currentPetCounts) do
        local prevCount = previousPetCounts[petName] or 0
        
        if currentCount > prevCount then
            -- Gọi hàm phân loại an toàn hơn
            local petType, color = classifyPet(petName)
            
            if petType then
                sendToDiscord(petName, currentCount, petType, color)
            end
        end
    end

    previousPetCounts = currentPetCounts
end

-- =============================================
--  VÒNG LẶP GIÁM SÁT
-- =============================================
task.spawn(function()
    while true do
        pcall(checkForNewPet)
        task.wait(2) 
    end
end)

print("🟢 Script lọc Huge/Titanic/Gold/Rainbow (Chuẩn xác) đã sẵn sàng!")
