local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"
local HubName = "SonNg" -- Tên hiển thị dưới chân thông báo

-- =============================================
--  HÀM GỬI WEBHOOK (Format theo mẫu Bảng)
-- =============================================
local HttpService = game:GetService("HttpService")
local reqFunc = syn and syn.request or (http and http.request) or request

local function sendToDiscord(petName, petType, totalCount, color, emoji)
    local playerName = game.Players.LocalPlayer.Name
    
    local data = {
        ["embeds"] = {{
            ["title"] = emoji .. "  " .. petType:upper() .. " HATCHED!",
            ["color"] = color, -- Màu sắc cho từng loại pet
            ["fields"] = {
                {
                    ["name"] = "🐾 Pet",
                    ["value"] = "```" .. petName .. "```", -- Dùng code block để thẳng hàng
                    ["inline"] = true
                },
                {
                    ["name"] = "👤 Player",
                    ["value"] = "```" .. playerName .. "```",
                    ["inline"] = true
                },
                {
                    ["name"] = "🎮 Total",
                    ["value"] = "```" .. tostring(totalCount) .. "```", -- Tổng số pet trong inv
                    ["inline"] = true
                }
            },
            ["footer"] = { 
                ["text"] = HubName .. "  •  Pet Simulator 99"
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }

    pcall(function()
        reqFunc({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- =============================================
--  CỐT LÕI: ĐỌC DỮ LIỆU PET & LẤY TỔNG SỐ LƯỢNG
-- =============================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveModule

local ok, mod = pcall(function()
    return require(ReplicatedStorage.Library.Client.Save)
end)
if ok then SaveModule = mod end

if not SaveModule then
    warn("❌ Lỗi: Không tìm thấy module Save.")
    return
end

local previousPetCounts = {}
local firstRun = true

print("🟢 Đang tải dữ liệu Pet hiện tại...")

local function checkForHugeTitanic()
    local currentPetCounts = {}
    
    local success, data = pcall(function() return SaveModule.Get() end)
    if not success or not data or not data.Inventory or not data.Inventory.Pet then
        return 
    end

    -- Đếm số lượng từng loại Pet
    for _, petData in pairs(data.Inventory.Pet) do
        if petData.id then
            local name = petData.id
            local amount = petData._am or 1
            currentPetCounts[name] = (currentPetCounts[name] or 0) + amount
        end
    end

    -- Lần chạy đầu tiên: Ghi nhận số liệu
    if firstRun then
        previousPetCounts = currentPetCounts
        firstRun = false
        print("✅ Đã lưu dữ liệu Pet. Bắt đầu theo dõi Huge/Titanic...")
        return
    end

    -- So sánh sự thay đổi số lượng
    for petName, currentCount in pairs(currentPetCounts) do
        local lowerName = petName:lower()
        
        -- Chỉ lọc Huge / Titanic
        if lowerName:find("huge") or lowerName:find("titanic") then
            local prevCount = previousPetCounts[petName] or 0
            
            -- Nếu số lượng tăng lên => Vừa mới nở
            if currentCount > prevCount then
                
                -- Xác định loại Pet (Golden, Rainbow, Titanic, Huge)
                local petType = "Huge"
                local color = 16753920 -- Màu cam mặc định cho Huge
                local emoji = "🎉"
                
                if lowerName:find("titanic") then 
                    petType = "Titanic"
                    color = 9699539 -- Màu tím
                    emoji = "💎"
                elseif lowerName:find("golden") then
                    petType = "Golden Huge"
                    color = 16766720 -- Màu vàng
                    emoji = "✨"
                elseif lowerName:find("rainbow") then
                    petType = "Rainbow Huge"
                    color = 16711935 -- Màu hồng
                    emoji = "🌈"
                end

                -- Gửi thông báo kèm theo TỔNG SỐ LƯỢNG hiện có (currentCount)
                print("🎉 Phát hiện: " .. petName)
                sendToDiscord(petName, petType, currentCount, color, emoji)
            end
        end
    end

    -- Cập nhật lại danh sách cũ
    previousPetCounts = currentPetCounts
end

-- =============================================
--  BẮT ĐẦU VÒNG LẶP GIÁM SÁT
-- =============================================
task.spawn(function()
    while true do
        pcall(checkForHugeTitanic)
        task.wait(3) -- 3 giây check 1 lần
    end
end)

print("🟢 Script đang chạy...")
