getgenv().PrivateServerCode1 = "92884917368738392535007079413789"
getgenv().PrivateServerCode2 = "85951203710875663196976345559936"
getgenv().TotalBoss = 3

local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local PLACE_ID = 8737899170

if not getgenv().CurrentServer then
    getgenv().CurrentServer = 1
end

-- ============================
-- GUI
-- ============================
if game.CoreGui:FindFirstChild("HopUI") then game.CoreGui.HopUI:Destroy() end
local sg = Instance.new("ScreenGui")
sg.Name = "HopUI"
sg.Parent = game.CoreGui

local label = Instance.new("TextLabel")
label.Size = UDim2.new(0, 250, 0, 80)
label.Position = UDim2.new(0, 10, 0, 10)
label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
label.BackgroundTransparency = 0.3
label.TextColor3 = Color3.fromRGB(0, 255, 100)
label.Font = Enum.Font.Code
label.TextSize = 14
label.TextWrapped = true
label.Text = "Dang vao server..."
label.Parent = sg

-- ============================
-- HÀM
-- ============================
local function updateUI(text)
    pcall(function()
        label.Text = text
    end)
end

local function getJobIdFromCode(code)
    local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/private-servers?privateServerLinkCode=" .. code
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success and result then
        local data = HttpService:JSONDecode(result)
        if data.data and #data.data > 0 then
            return data.data[1].id
        end
    end
    
    return nil
end

local function hopToPrivateServer(code)
    local jobId = getJobIdFromCode(code)
    if jobId then
        pcall(function()
            TeleportService:TeleportToPlaceInstance(PLACE_ID, jobId, player)
        end)
    end
end

local function joinEvent()
    local libraryFolder = ReplicatedStorage:WaitForChild("Library", 30)
    if libraryFolder then
        local ClientFolder = libraryFolder:WaitForChild("Client", 15)
        local InstancingCmds = require(ClientFolder:WaitForChild("InstancingCmds"))
        local FFlags = require(ClientFolder:WaitForChild("FFlags"))
        
        local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
        if joinTarget then
            InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
        end
    end
end

local function countBosses()
    local Breakables = workspace:FindFirstChild("__THINGS")
    if Breakables then
        Breakables = Breakables:FindFirstChild("Breakables")
        if Breakables then
            local bosses = 0
            for _, breakable in ipairs(Breakables:GetChildren()) do
                if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
                    bosses = bosses + 1
                end
            end
            return bosses
        end
    end
    return 0
end

local function checkAndHop()
    updateUI("Server " .. getgenv().CurrentServer .. " - Dang doi 18s...")
    task.wait(18)
    
    updateUI("Server " .. getgenv().CurrentServer .. " - Dang vao event...")
    joinEvent()
    
    -- Quét boss liên tục trong lúc chờ
    for i = 7, 1, -1 do
        local bosses = countBosses()
        updateUI("Server " .. getgenv().CurrentServer .. " - Event: " .. i .. "s\nBoss: " .. bosses)
        task.wait(1)
    end
    
    local bosses = countBosses()
    
    if bosses >= getgenv().TotalBoss then
        updateUI("🔥 TIM THAY " .. bosses .. " BOSS!\nServer " .. getgenv().CurrentServer .. " - O LAI")
    else
        updateUI("❌ " .. bosses .. "/" .. getgenv().TotalBoss .. " boss\nDang chuyen server...")
        task.wait(2)
        
        if getgenv().CurrentServer == 1 then
            getgenv().CurrentServer = 2
            hopToPrivateServer(getgenv().PrivateServerCode2)
        else
            getgenv().CurrentServer = 1
            hopToPrivateServer(getgenv().PrivateServerCode1)
        end
    end
end

checkAndHop()
