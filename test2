-- =============================================
--  BƯỚC 1: DÒ TÌM PET SERVICE TRONG PS99
-- =============================================
print("🟢 Bắt đầu dò tìm PetService...")

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- 1. Tìm PetService (Nơi chứa toàn bộ Pet thật sự trong PS99)
local petService = localPlayer:FindFirstChild("PetService")

if petService then
    print("✅ Đã tìm thấy PetService!")
    
    -- 2. Liệt kê các con Pet hiện có (Để xem cấu trúc nó ra sao)
    local allPets = petService:GetChildren()
    print("📊 Tổng số Pet bạn đang có: " .. #allPets)
    
    -- In ra tên 5 con pet đầu tiên để kiểm tra
    print("📋 5 con pet đầu tiên trong danh sách:")
    for i = 1, math.min(5, #allPets) do
        local pet = allPets[i]
        -- In ra tên thật của Pet (Không phải tên hiển thị)
        print("  - Pet " .. i .. ": " .. tostring(pet))
    end
    
    -- 3. Kiểm tra xem khi nở trứng, PetService có tự động thêm Pet mới không
    print("🟡 (Đang chờ bạn nở trứng để xem PetService thay đổi...)")
    
    -- Đếm số lượng Pet hiện tại
    local currentCount = #petService:GetChildren()
    
    -- Vòng lặp chờ đợi sự thay đổi (Cứ 1 giây check 1 lần)
    spawn(function()
        while task.wait(1) do
            local newCount = #petService:GetChildren()
            if newCount > currentCount then
                print("🎉 PHÁT HIỆN THAY ĐỔI! Số Pet đã tăng từ " .. currentCount .. " lên " .. newCount)
                
                -- Lấy con Pet mới nhất (Thường là con vừa nở)
                local newPet = petService:GetChildren()[newCount]
                print("👉 Tên Pet vừa thêm vào Service: " .. tostring(newPet))
                
                -- Cập nhật lại số lượng mới để so sánh lần sau
                currentCount = newCount
            end
        end
    end)
    
else
    warn("❌ KHÔNG TÌM THẤY PetService!")
    warn("👉 Hãy thử tìm các tên khác như: localPlayer:FindFirstChild('Pets') hoặc localPlayer:FindFirstChild('PetInventoryService')")
    
    -- Thử tìm các tên dự phòng
    local backupNames = {"Pets", "PetInventoryService", "InventoryService", "OwnedPets"}
    for _, name in ipairs(backupNames) do
        local found = localPlayer:FindFirstChild(name)
        if found then
            print("✅ Tìm thấy tên dự phòng: " .. name)
        end
    end
end
