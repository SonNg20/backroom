-- Debug: In ra tất cả Attribute của object mới spawn
workspace.__THINGS.Breakables.ChildAdded:Connect(function(inst)
    if inst:IsA("Model") then
        print("=== Mini Chest Spawned ===")
        print("Name:", inst.Name)
        print("Class:", inst.ClassName)
        
        -- In tất cả Attributes
        local attrs = inst:GetAttributes()
        for k, v in pairs(attrs) do
            print("Attribute:", k, "=", v)
        end
        print("=========================")
    end
end)
