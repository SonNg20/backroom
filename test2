local HttpService = game:GetService("HttpService")
local reqFunc = syn and syn.request or (http and http.request) or request

local function sendToDiscord(petName, totalCount, petType, color)
    local playerName = game.Players.LocalPlayer.Name
    local currentTime = os.date("%H:%M:%S")
    
    local titles = {
        Titanic = "💎 TITANIC PET CAUGHT! ✨",
        Golden = "✨ GOLDEN HUGE CAUGHT! ✨",
        Rainbow = "🌈 RAINBOW HUGE CAUGHT! 🌈",
        Huge = "🎉 HUGE PET CAUGHT! 🔥"
    }
    
    local data = {
        ["embeds"] = {{
            ["title"] = titles[petType] or "🎉 HUGE PET CAUGHT! 🔥",
            ["color"] = color,
            ["fields"] = {
                { ["name"] = "🐾 **Pet:**", ["value"] = "**" .. petName .. "**", ["inline"] = true },
                { ["name"] = "👤 **User:**", ["value"] = "||**" .. playerName .. "**||", ["inline"] = true },
                { ["name"] = "⏰ **Time:**", ["value"] = "`" .. currentTime .. "`", ["inline"] = true },
                { ["name"] = "📦 **Total:**", ["value"] = "`" .. tostring(totalCount) .. "`", ["inline"] = true }
            },
            ["footer"] = { ["text"] = "⚡ powered by " .. HubName .. " - " .. os.date("%H:%M ngày %d/%m") }
        }}
    }

    pcall(function()
        reqFunc({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    print("✅ Đã gửi " .. petType .. ": " .. petName)
end

-- =============================================
--  CỐT LÕI MỚI: LẤY DỮ LIỆU & PHÂN LOẠI TỪ CONFIG (SKIN)
-- =============================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveModule

local ok, mod = pcall(function()
    return require(ReplicatedStorage.Library.Client.Save)
end)
if ok then SaveModule = mod end

if not SaveModule then
    warn("❌ Lỗi: Không tìm thấy module Save.")
    return
end

local previousPetCounts = {}
local firstRun = true

print("🟢 Đang tải dữ liệu Pet hiện tại...")

-- Hàm phân loại dựa trên Config của Pet (Không dựa vào tên)
local function classifyPet(petID, petData)
    local lowerName = petID:lower()
    
    -- 1. Dùng tên để bắt Titanic trước (Cái này tên nó vẫn giữ chữ Titanic)
    if lowerName:find("titanic") then
        return "Titanic", 9699539 -- Màu Tím
    end
    
    -- 2. Nếu không phải Titanic, bắt đầu kiểm tra các loại Huge
    if lowerName:find("huge") then
        
        -- Đọc màu sắc từ thuộc tính trong dữ liệu game
        local skinData = petData.skin or petData.Config or {}
        local colorID = skinData.Color or "Default"
        
        -- Nếu có thuộc tính Golden (Màu vàng đặc trưng)
        if colorID == "Golden" or lowerName:find("golden") then
            return "Golden", 16766720 -- Vàng óng
            
        -- Nếu có thuộc tính Rainbow (Màu ảo giác)
        elseif colorID == "Rainbow" or lowerName:find("rainbow") then
            return "Rainbow", 16711935 -- Hồng cánh sen
            
        -- Còn lại là Huge thường
        else
            return "Huge", 16753920 -- Màu Cam
        end
    end
    
    return nil, nil
end

local function checkForNewPet()
    local currentPetData = {} -- Lưu cả tên và config để phân biệt màu
    
    local success, data = pcall(function() return SaveModule.Get() end)
    if not success or not data or not data.Inventory or not data.Inventory.Pet then
        return 
    end

    -- Đếm số lượng và lưu cấu hình pet
    for _, petData in pairs(data.Inventory.Pet) do
        if petData.id then
            local name = petData.id
            local amount = petData._am or 1
            if not currentPetData[name] then
                currentPetData[name] = { count = 0, config = petData }
            end
            currentPetData[name].count = currentPetData[name].count + amount
        end
    end

    -- Lần chạy đầu
    if firstRun then
        previousPetCounts = currentPetData
        firstRun = false
        print("✅ Đã lưu dữ liệu Pet. Bắt đầu theo dõi...")
        return
    end

    -- So sánh sự thay đổi
    for petName, currentInfo in pairs(currentPetData) do
        local prevInfo = previousPetCounts[petName]
        local prevCount = prevInfo and prevInfo.count or 0
        
        if currentInfo.count > prevCount then
            
            -- Gọi hàm phân loại bằng Config 
            local petType, color = classifyPet(petName, currentInfo.config)
            
            if petType then
                sendToDiscord(petName, currentInfo.count, petType, color)
            end
        end
    end

    previousPetCounts = currentPetData
end

-- =============================================
--  VÒNG LẶP GIÁM SÁT
-- =============================================
task.spawn(function()
    while true do
        pcall(checkForNewPet)
        task.wait(2) 
    end
end)

print("🟢 Script phân biệt Gold/Rainbow thực tế đã sẵn sàng!")
