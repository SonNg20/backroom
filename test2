local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"
local HubName = "RLWSCRIPTS" -- Tên hiển thị dưới cùng

-- =============================================
--  HÀM GỬI WEBHOOK
-- =============================================
local HttpService = game:GetService("HttpService")
local reqFunc = syn and syn.request or (http and http.request) or request

local function sendToDiscord(petName, totalCount, petType, color)
    local playerName = game.Players.LocalPlayer.Name
    local currentTime = os.date("%H:%M:%S")
    
    -- Tạo tiêu đề dựa trên loại pet
    local titles = {
        Titanic = "💎 TITANIC PET CAUGHT! ✨",
        Rainbow = "🌈 RAINBOW HUGE CAUGHT! 🌈",
        Golden = "✨ GOLDEN HUGE CAUGHT! ✨",
        Huge = "🎉 HUGE PET CAUGHT! 🔥"
    }
    
    local data = {
        ["embeds"] = {{
            ["title"] = titles[petType] or "🎉 HUGE PET CAUGHT! 🔥",
            ["color"] = color,
            ["fields"] = {
                {
                    ["name"] = "🐾 **Pet:**",
                    ["value"] = "**" .. petName .. "**",
                    ["inline"] = true
                },
                {
                    ["name"] = "👤 **User:**",
                    ["value"] = "||**" .. playerName .. "**||", -- Ẩn tên
                    ["inline"] = true
                },
                {
                    ["name"] = "⏰ **Time:**",
                    ["value"] = "`" .. currentTime .. "`",
                    ["inline"] = true
                },
                {
                    ["name"] = "📦 **Total:**",
                    ["value"] = "`" .. tostring(totalCount) .. "`",
                    ["inline"] = true
                }
            },
            ["footer"] = { 
                ["text"] = "⚡ powered by " .. HubName .. " - " .. os.date("%H:%M ngày %d/%m")
            }
        }}
    }

    pcall(function()
        reqFunc({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
    print("✅ Đã gửi " .. petType .. ": " .. petName)
end

-- =============================================
--  BẮT ĐẦU LẤY DỮ LIỆU GAME
-- =============================================
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SaveModule

local ok, mod = pcall(function()
    return require(ReplicatedStorage.Library.Client.Save)
end)
if ok then SaveModule = mod end

if not SaveModule then
    warn("❌ Lỗi: Không tìm thấy module Save.")
    return
end

local previousPetCounts = {}
local firstRun = true

print("🟢 Đang tải dữ liệu Pet hiện tại...")

-- Hàm phân loại chính xác Huge/Golden/Rainbow/Titanic
local function checkPetType(name)
    local lower = name:lower()
    
    -- Ưu tiên kiểm tra Titanic trước
    if lower:find("titanic") then
        return "Titanic", 9699539 -- Màu Tím
    end
    
    -- Kiểm tra các loại Huge
    if lower:find("golden") and lower:find("huge") then
        return "Golden", 16766720 -- Màu Vàng óng
    end
    
    if lower:find("rainbow") and lower:find("huge") then
        return "Rainbow", 16711935 -- Màu Hồng
    end
    
    if lower:find("huge") then
        return "Huge", 16753920 -- Màu Cam
    end
    
    return nil, nil -- Không phải Huge/Titanic
end

local function checkForNewPet()
    local currentPetCounts = {}
    
    local success, data = pcall(function() return SaveModule.Get() end)
    if not success or not data or not data.Inventory or not data.Inventory.Pet then
        return 
    end

    -- Đếm số lượng pet hiện tại
    for _, petData in pairs(data.Inventory.Pet) do
        if petData.id then
            local name = petData.id
            local amount = petData._am or 1
            currentPetCounts[name] = (currentPetCounts[name] or 0) + amount
        end
    end

    -- Lần chạy đầu: Ghi nhận số liệu
    if firstRun then
        previousPetCounts = currentPetCounts
        firstRun = false
        print("✅ Đã lưu dữ liệu Pet. Chỉ theo dõi Huge/Titanic...")
        return
    end

    -- So sánh sự thay đổi
    for petName, currentCount in pairs(currentPetCounts) do
        local prevCount = previousPetCounts[petName] or 0
        
        -- Nếu số pet tăng lên
        if currentCount > prevCount then
            
            -- Gọi hàm phân loại
            local petType, color = checkPetType(petName)
            
            -- Nếu là 1 trong các loại Huge/Titanic thì gửi thông báo
            if petType then
                sendToDiscord(petName, currentCount, petType, color)
            end
        end
    end

    previousPetCounts = currentPetCounts
end

-- =============================================
--  VÒNG LẶP GIÁM SÁT (Mỗi 2 giây)
-- =============================================
task.spawn(function()
    while true do
        pcall(checkForNewPet)
        task.wait(2) 
    end
end)

print("🟢 Script lọc Huge/Titanic (Chuẩn xác) đã sẵn sàng!")
