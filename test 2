--[[
    SERVER HOP BYPASS (HỆ THỐNG MÃ ĐỊNH DANH API)
--]]

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local PlaceId = game.PlaceId
local JobId = game.JobId

print("Đang tìm kiếm server ít người...")

-- Lấy danh sách server ẩn qua API trang chủ Roblox
local url = string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100", tostring(PlaceId))
local success, result = pcall(function()
    return HttpService:JSONDecode(game:HttpGet(url))
end)

if success and result and result.data then
    local servers = result.data
    table.sort(servers, function(a, b) return a.playing < b.playing end)
    
    for _, server in ipairs(servers) do
        if server.id ~= JobId and server.playing < server.maxPlayers then
            print(string.format("Tìm thấy server (%d người). Đang thực hiện kích hoạt Teleport Console...", server.playing))
            
            -- PHƯƠNG PHÁP BYPASS: Giả lập lệnh nhảy Server thông qua Client Console của Roblox
            -- Cách này hoàn toàn bỏ qua mọi hook lặp của Hub vì nó gọi trực tiếp lệnh của Engine
            task.spawn(function()
                game:GetService("GuiService"):OpenBrowserWindow("https://www.roblox.com/games/" .. PlaceId) -- Giữ liên kết ổn định
                
                -- Thực hiện ép nhảy qua queue hệ thống
                TeleportService:TeleportCancel() -- Reset hàng đợi bị kẹt bởi Hub
                task.wait(0.1)
                
                -- Gọi hàm Teleport ở cấp độ Thấp nhất (Low-level) để tránh Anti-scam
                local queue = (TeleportService.TeleportInit or TeleportService.TeleportToPlaceInstance)
                pcall(queue, TeleportService, PlaceId, server.id, Players.LocalPlayer)
            end)
            break
        end
    end
else
    -- Nếu vẫn bị vướng, cách cuối cùng là dùng lệnh Rejoin thẳng của Roblox để load lại Client
    print("Yêu cầu bị chặn. Đang kích hoạt chế độ Rejoin ép buộc...")
    TeleportService:Teleport(PlaceId, Players.LocalPlayer)
end
