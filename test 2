-- ============ PHẦN 2: QUÉT BOSS ============
local function scanBosses()
    -- Kiểm tra xem đã join event chưa (check workspace có Breakables không)
    local success, breakables = pcall(function()
        return workspace.__THINGS.Breakables
    end)
    
    if not success or not breakables then
        bossCountLabel.Text = "⏳ Chưa vào event..."
        bossCountLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
        return 0
    end
    
    local bosses = 0
    local bossNames = {}
    
    for _, breakable in ipairs(breakables:GetChildren()) do
        if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
            bosses += 1
            table.insert(bossNames, breakable.Name or "Unknown")
        end
    end
    
    -- Cập nhật UI
    if bosses >= 3 then
        bossCountLabel.Text = string.format("⚠️ %d BOSSES PHÁT HIỆN!", bosses)
        bossCountLabel.TextColor3 = Color3.fromRGB(255, 50, 50) -- Đỏ cảnh báo
        print(string.format("⚠️ [BOSS ALERT] %d bosses detected!", bosses))
        for i, name in ipairs(bossNames) do
            print(string.format("  - Boss %d: %s", i, name))
        end
    elseif bosses > 0 then
        bossCountLabel.Text = string.format("👾 Số Boss: %d", bosses)
        bossCountLabel.TextColor3 = Color3.fromRGB(100, 255, 100) -- Xanh
        print(string.format("📊 %d boss(es) detected in event", bosses))
    else
        bossCountLabel.Text = "✅ Không có boss nào"
        bossCountLabel.TextColor3 = Color3.fromRGB(100, 200, 255) -- Xanh dương
    end
    
    return bosses
end

-- ============ PHẦN 3: AUTO JOIN + QUÉT BOSS ============
local isInEvent = false
local joinAttempts = 0
local maxJoinAttempts = 3

local function autoJoinAndScan()
    local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
    
    if joinTarget and not isInEvent then
        joinAttempts = joinAttempts + 1
        
        if joinAttempts > maxJoinAttempts then
            eventStatusLabel.Text = "❌ Không thể join event!"
            eventStatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            return
        end
        
        eventStatusLabel.Text = "🎮 Đang join event..."
        eventStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        local success, err = pcall(function()
            InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
        end)
        
        if success then
            isInEvent = true
            eventStatusLabel.Text = "✅ Đã vào event!"
            eventStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            joinAttempts = 0
            
            -- Đợi 1 giây để event load xong rồi quét boss
            task.wait(1)
            scanBosses()
            
            -- Bắt đầu quét boss liên tục
            startBossScanning()
        else
            eventStatusLabel.Text = "❌ Join thất bại: " .. tostring(err):sub(1, 30)
            eventStatusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            warn("Join failed:", err)
        end
    elseif not joinTarget then
        eventStatusLabel.Text = "⏳ Chưa có event..."
        eventStatusLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
        isInEvent = false
        joinAttempts = 0
        bossCountLabel.Text = "👾 Đợi vào event..."
        bossCountLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

-- ============ PHẦN 4: QUÉT BOSS LIÊN TỤC ============
local scanConnection = nil
local isScanning = false

local function startBossScanning()
    if isScanning then return end
    isScanning = true
    
    -- Quét boss mỗi 2 giây
    scanConnection = game:GetService("RunService").Heartbeat:Connect(function(deltaTime)
        if tick() % 2 < deltaTime then
            scanBosses()
        end
    end)
end

local function stopBossScanning()
    if scanConnection then
        scanConnection:Disconnect()
        scanConnection = nil
        isScanning = false
    end
end

-- ============ PHẦN 5: THEO DÕI THAY ĐỔI ============
-- Quét tự động mỗi 1 giây để bắt event
local autoJoinConnection
autoJoinConnection = game:GetService("RunService").Heartbeat:Connect(function(deltaTime)
    if tick() % 1 < deltaTime then
        autoJoinAndScan()
    end
end)

-- Theo dõi khi Breakables xuất hiện (vào event)
local breakablesConnection
local function setupBreakablesWatcher()
    local success, breakables = pcall(function()
        return workspace.__THINGS.Breakables
    end)
    
    if success and breakables then
        if breakablesConnection then
            breakablesConnection:Disconnect()
        end
        
        breakablesConnection = breakables.ChildAdded:Connect(function()
            scanBosses()
        end)
        
        breakablesConnection = breakables.ChildRemoved:Connect(function()
            scanBosses()
        end)
    end
end

-- Thử thiết lập watcher mỗi 3 giây
game:GetService("RunService").Heartbeat:Connect(function(deltaTime)
    if tick() % 3 < deltaTime then
        setupBreakablesWatcher()
    end
end)

