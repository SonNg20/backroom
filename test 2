--[[
    SCRIPT BYPASS CƠ CHẾ CHẶN SERVER HOP CỦA HUB
    Chạy đoạn này TRƯỚC khi chạy script Server Hop của bạn
--]]

-- 1. Khôi phục trực tiếp hàm Teleport ẩn thông qua GetService tĩnh
local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlaceId = game.PlaceId

print("Đang cố gắng bypass Anti-Scam của Hub...")

-- 2. Thử phá vỡ các hàm hook phổ biến bằng cách gọi trực tiếp nguyên bản dữ liệu
local function bypassAndHop()
    -- Lấy danh sách server ít người từ API ẩn (Bypass qua HttpGet trực tiếp)
    local success, result = pcall(function()
        return game:HttpServiceDecode(game:HttpGet(string.format("https://games.roblox.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100", tostring(PlaceId))))
    end)
    
    if success and result and result.data then
        -- Sắp xếp tìm server ít người
        local servers = result.data
        table.sort(servers, function(a, b) return a.playing < b.playing end)
        
        for _, server in ipairs(servers) do
            if server.id ~= game.JobId and server.playing < server.maxPlayers then
                print("Tìm thấy server hợp lệ. Đang ép xung Teleport...")
                
                -- Thực hiện ép nhảy server (Sử dụng task.spawn để cô lập tiến trình tránh bị Hub bắt bài)
                task.spawn(function()
                    for i = 1, 5 do -- Thử lại 5 lần liên tục để phá bộ lọc đè
                        pcall(function()
                            TeleportService:TeleportToPlaceInstance(PlaceId, server.id, LocalPlayer)
                        end)
                        task.wait(0.2)
                    end
                end)
                break
            end
        end
    else
        -- Phương án dự phòng cưỡng ép rời phòng bằng Teleport mặc định
        task.spawn(function()
            pcall(function() TeleportService:Teleport(PlaceId, LocalPlayer) end)
        end)
    end
end

-- Chạy hàm cưỡng ép chuyển server
bypassAndHop()
