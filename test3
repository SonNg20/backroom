local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

print("--- SCANNING ALL PLAYER BOOTHS ---")

-- Tìm thư mục chứa các Booth
local BoothsFolder = Workspace:FindFirstChild("Map") 
    and Workspace.Map:FindFirstChild("Booths") 
    or Workspace:FindFirstChild("Booths")

if not BoothsFolder then
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "Booths" and obj:IsA("Folder") then
            BoothsFolder = obj
            break
        end
    end
end

if BoothsFolder then
    for _, booth in ipairs(BoothsFolder:GetChildren()) do
        -- Lấy tên chủ Booth
        local ownerID = booth:GetAttribute("OwnerID") or booth:GetAttribute("Owner")
        local ownerName = "Unknown"
        
        if ownerID then
            local p = Players:GetPlayerByUserId(tonumber(ownerID))
            if p then
                ownerName = p.Name
            else
                ownerName = "ID: " .. tostring(ownerID)
            end
        end
        
        -- Quét tất cả UI quảng cáo/bán hàng đính kèm trên mô hình Booth
        local boothPrinted = false
        
        for _, desc in ipairs(booth:GetDescendants()) do
            -- Tìm các BillboardGui hoặc SurfaceGui hiển thị thông tin giá/vật phẩm
            if desc:IsA("TextLabel") or desc:IsA("TextBox") then
                local text = desc.Text
                
                -- Lọc các TextLabel chứa thông tin giá bán hoặc tên vật phẩm
                -- Thường text sẽ có dạng số kèm biểu tượng hoặc text chứa giá trị cụ thể
                if text and text ~= "" and not desc.Parent:IsA("TextBox") then
                    -- Kiểm tra xem text có phải là thông tin bán hàng (chứa giá trị, chữ số, gems, hoặc x1, x5...)
                    local isItemOrPrice = text:find("%d") or text:find("x%d") or text:find("💎") or text:find("Gems")
                    
                    if isItemOrPrice and not text:find("Booth") and not text:find("'s") then
                        if not boothPrinted then
                            print("\n[BOOTH] Owner: " .. ownerName)
                            boothPrinted = true
                        end
                        print("   -> Detail: " .. text)
                    end
                end
            end
        end
    end
else
    warn("Booths folder not found!")
end

print("\n--- SCAN COMPLETE ---")
