local Library = require(game:GetService("ReplicatedStorage").Library)
local ItemCmds = Library.ItemCmds

-- Dẫn thẳng vào module BoothCmds để lấy table lưu trữ cache (v_u_48)
local BoothCmds = require(game:GetService("ReplicatedStorage").Library.Client.BoothCmds)

-- Khai thác biến môi trường (getupvalues) để lấy table v_u_48 chứa toàn bộ dữ liệu Booth trong server
local boothCache = nil
for _, v in ipairs(debug.getupvalues(BoothCmds.getState or BoothCmds.getByOwnerId)) do
    if type(v) == "table" and not v.Raw and next(v) then
        -- Kiểm tra xem table này có phải là table chứa thông tin player không
        local firstKey = next(v)
        if typeof(firstKey) == "Instance" and firstKey:IsA("Player") then
            boothCache = v
            break
        end
    end
end

-- Phương án dự phòng nếu không getupvalue được (sử dụng quét vòng lặp player)
if not boothCache then
    boothCache = {}
    for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
        local state = BoothCmds.getState(player)
        if state then
            boothCache[player] = state
        end
    end
end

print("--- SCANNING ALL PLAYER BOOTHS (SOURCE FIXED) ---")

if boothCache and next(boothCache) then
    for player, boothData in pairs(boothCache) do
        if boothData and boothData.Listings then
            
            -- Sửa lỗi BoothID = Model: Lấy trực tiếp ID số/chuỗi từ data hệ thống
            local boothID = boothData.BoothID or "Unknown"
            local boothDirID = boothData.BoothDirID or "Noob"
            local sitting = tostring(boothData.Sitting or false)
            local playerID = boothData.PlayerID or (player and player.UserId) or "Unknown"
            local lifetimeSales = boothData.LifetimeSales or 0
            
            print(string.format("BoothID = %s", tostring(boothID)))
            print(string.format("BoothDirID = %s", tostring(boothDirID)))
            print(string.format("Sitting = %s", tostring(sitting)))
            print(string.format("PlayerID = %s", tostring(playerID)))
            print(string.format("LifetimeSales = %s", tostring(lifetimeSales)))
            print("Listings:")
            
            for listingID, details in pairs(boothData.Listings) do
                local price = details.DiamondCost or 0
                local timestamp = details.Timestamp or 0
                local readyTimestamp = details.ReadyTimestamp or 3.5
                
                local itemClass = "Unknown"
                local itemID = "Unknown"
                local uid = "N/A"
                
                -- Khai thác chính xác từ Object Item (Khởi tạo từ v_u_3.From)
                local itemObj = details.Item
                if itemObj then
                    -- Lấy class
                    itemClass = itemObj.class or (itemObj.GetClass and itemObj:GetClass()) or "Unknown"
                    
                    -- Lấy ID hiển thị gốc (ví dụ: Rave, Banana...) thay vì chuỗi hash
                    itemID = itemObj.id or (itemObj.GetId and itemObj:GetId()) or "Unknown"
                    
                    -- Lấy UID thực của vật phẩm
                    uid = itemObj.uid or (itemObj.GetUID and itemObj:GetUID()) or "N/A"
                end
                
                -- In ra Console phân cấp chuẩn 100% tiếng Anh
                print(string.format("    %s:", tostring(listingID)))
                print(string.format("        DiamondCost = %s", tostring(price)))
                print(string.format("        Timestamp = %s", tostring(timestamp)))
                print(string.format("        ReadyTimestamp = %s", tostring(readyTimestamp)))
                print("        ItemData:")
                print(string.format("            class = %s", tostring(itemClass)))
                print("            data:")
                print(string.format("                id = %s", tostring(itemID)))
                print(string.format("                uid = %s", tostring(uid)))
            end
            print("----------------------------------------")
        end
    end
else
    print("No active booths found in the BoothCmds cache.")
end

print("\n--- SCAN COMPLETE ---")
