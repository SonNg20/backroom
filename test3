-- =============================================
--   SONG HUB - PS99 ORB AUTO COLLECTOR
--   SoccerEvent - ClaimOrb via FireServer
-- =============================================

local CONFIG = {
    Rarities = {
        Basic     = true,
        Rare      = true,
        Epic      = true,
        Legendary = true,
        Mythical  = true,
    },
    LoopDelay = 0.1, -- giây giữa mỗi lần nhặt
}

-- =============================================
local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local lp                = Players.LocalPlayer
local debris            = workspace:WaitForChild("__DEBRIS")
local Network           = ReplicatedStorage:WaitForChild("Network")
local fireCustom        = Network:WaitForChild("Instancing_FireCustomFromClient")

-- =============================================
--  LẤY ID CỦA ORB
-- =============================================
local function getOrbID(orb)
    -- Thử các attribute phổ biến PS99 dùng để lưu ID
    local id = orb:GetAttribute("ID")
              or orb:GetAttribute("Id")
              or orb:GetAttribute("OrbID")
              or orb:GetAttribute("UID")
              or orb:GetAttribute("Index")
    return id
end

-- =============================================
--  NHẶT 1 ORB
-- =============================================
local function claimOrb(orb)
    if not orb or not orb.Parent then return end
    local id = getOrbID(orb)
    if not id then return end

    fireCustom:FireServer("SoccerEvent", "ClaimOrb", id)
end

-- =============================================
--  LẤY TẤT CẢ ORB HIỆN TẠI
-- =============================================
local function getAllOrbs()
    local orbs = {}
    for rarity, on in pairs(CONFIG.Rarities) do
        if on then
            local folder = debris:FindFirstChild(rarity)
            if folder then
                for _, orb in ipairs(folder:GetChildren()) do
                    if orb:IsA("BasePart") and orb.Name == "Orb" then
                        table.insert(orbs, orb)
                    end
                end
            end
        end
    end
    return orbs
end

-- =============================================
--  VÒNG LẶP CHÍNH
-- =============================================
_G.StopOrb = false

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print("  Song Hub — Orb Collector")
print("  SoccerEvent / ClaimOrb")
print("  _G.StopOrb = true để dừng")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━")

-- Debug: in thử ID của orb đầu tiên tìm được
task.delay(1, function()
    local orbs = getAllOrbs()
    if #orbs > 0 then
        local testOrb = orbs[1]
        print("[DEBUG] Test orb: " .. testOrb:GetFullName())
        for _, attr in ipairs({"ID","Id","OrbID","UID","Index"}) do
            local v = testOrb:GetAttribute(attr)
            if v then print("[DEBUG] Attribute " .. attr .. " = " .. tostring(v)) end
        end
    else
        print("[DEBUG] Không tìm thấy orb nào!")
    end
end)

task.spawn(function()
    while not _G.StopOrb do
        local orbs = getAllOrbs()
        for _, orb in ipairs(orbs) do
            if _G.StopOrb then break end
            claimOrb(orb)
            task.wait(0.05)
        end
        task.wait(CONFIG.LoopDelay)
    end
    print("[Song Hub] Orb Collector đã dừng.")
end)
