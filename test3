-- ============================
-- AUTO COLLECT SOCCER ORB - DÙNG REMOTE TỪ SIMPLESPY
-- ============================

if not game:IsLoaded() then game.Loaded:Wait() end

local ReplicatedStorage = game:GetService("ReplicatedStorage")

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            local orbs = workspace.__THINGS:FindFirstChild("Orbs")
            if not orbs then return end
            
            for _, orb in ipairs(orbs:GetChildren()) do
                if orb:IsA("BasePart") then
                    local orbNumber = tonumber(orb.Name)
                    if orbNumber then
                        local args = {
                            [1] = "SoccerEvent",
                            [2] = "ClaimOrb",
                            [3] = orbNumber
                        }
                        
                        ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(unpack(args))
                    end
                end
            end
        end)
    end
end)
