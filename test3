local Library = require(game:GetService("ReplicatedStorage").Library)
-- Định vị hàm khởi tạo vật phẩm (chính là v_u_3 trong đoạn code của bạn, thường là Library.Item hoặc một module ItemCore)
local ItemDirectory = Library.Item or Library.ItemCmds 

print("--- SCANNING ALL PLAYER BOOTHS (SOURCE LOGIC INTEGRATED) ---")

local BoothsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Booths")

if BoothsFolder then
    for _, booth in ipairs(BoothsFolder:GetChildren()) do
        local petsFolder = booth:FindFirstChild("Pets")
        local boothTop = petsFolder and petsFolder:FindFirstChild("BoothTop")
        
        if boothTop and #boothTop:GetChildren() > 0 then
            local boothID = booth:GetAttribute("BoothID") or booth:GetAttribute("ID") or booth.Name
            local boothDirID = booth:GetAttribute("BoothDirID") or "Noob"
            local sitting = booth:GetAttribute("Sitting") or false
            local playerID = booth:GetAttribute("OwnerID") or booth:GetAttribute("Owner") or "Unknown"
            local lifetimeSales = booth:GetAttribute("LifetimeSales") or 0
            
            print(string.format("BoothID = %s", tostring(boothID)))
            print(string.format("BoothDirID = %s", tostring(boothDirID)))
            print(string.format("Sitting = %s", tostring(sitting)))
            print(string.format("PlayerID = %s", tostring(playerID)))
            print(string.format("LifetimeSales = %s", tostring(lifetimeSales)))
            print("Listings:")
            
            for _, itemObj in ipairs(boothTop:GetChildren()) do
                -- Lấy dữ liệu thô tương ứng với cấu trúc dữ liệu của v246 trong vòng lặp game
                local rawData = itemObj:GetAttribute("Data") or itemObj:GetAttribute("ItemData")
                
                local price = itemObj:GetAttribute("Price") or itemObj:GetAttribute("DiamondCost") or 0
                local timestamp = itemObj:GetAttribute("Timestamp") or 0
                local readyTimestamp = itemObj:GetAttribute("ReadyTimestamp") or (timestamp + 3.5)
                
                local itemClass = "Unknown"
                local itemID = "Unknown"
                local uid = "N/A"
                
                if rawData then
                    local v246 = type(rawData) == "string" and Library.JSONDecode(rawData) or rawData
                    
                    if v246 and v246.ItemData then
                        -- Lấy thông tin dựa theo đúng cấu trúc v246.ItemData.class và v246.ItemData.data
                        itemClass = v246.ItemData.class or v246.ItemData.Class or itemClass
                        uid = v246.ItemData.uid or uid
                        
                        if v246.ItemData.data then
                            itemID = v246.ItemData.data.id or itemID
                        end
                        
                        -- Cập nhật lại giá trị DiamondCost chuẩn từ bảng dữ liệu gốc nếu có
                        price = v246.DiamondCost or price
                        timestamp = v246.Timestamp or timestamp
                        readyTimestamp = v246.ReadyTimestamp or readyTimestamp
                    end
                end
                
                -- Dự phòng nếu Attribute rỗng
                if itemID == "Unknown" then itemID = itemObj.Name end
                if itemClass == "Unknown" then itemClass = itemObj:GetAttribute("Class") or "Unknown" end
                
                -- In ra Console chuẩn định dạng phân cấp tiếng Anh
                print(string.format("    %s:", tostring(itemObj.Name)))
                print(string.format("        DiamondCost = %s", tostring(price)))
                print(string.format("        Timestamp = %s", tostring(timestamp)))
                print(string.format("        ReadyTimestamp = %s", tostring(readyTimestamp)))
                print("        ItemData:")
                print(string.format("            class = %s", tostring(itemClass)))
                print("            data:")
                print(string.format("                id = %s", tostring(itemID)))
                print(string.format("                uid = %s", tostring(uid)))
            end
            print("----------------------------------------")
        end
    end
else
    warn("Could not find workspace.__THINGS.Booths folder!")
end

print("\n--- SCAN COMPLETE ---")
