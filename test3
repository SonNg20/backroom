local Library = require(game:GetService("ReplicatedStorage").Library)
local ItemCmds = Library.ItemCmds
local BoothCmds = Library.BoothCmds

print("--- SCANNING ALL PLAYER BOOTHS ---")

for _, player in ipairs(game:GetService("Players"):GetPlayers()) do
    -- Sử dụng BoothCmds để lấy dữ liệu danh sách vật phẩm đang bán của người chơi
    local boothData = nil
    
    pcall(function()
        -- Gọi hàm lấy dữ liệu quầy từ Module (tùy phiên bản có thể là Get hoặc GetBooth)
        if BoothCmds.Get then
            boothData = BoothCmds.Get(player)
        elseif BoothCmds.GetBooth then
            boothData = BoothCmds.GetBooth(player)
        end
    end)
    
    -- Nếu không gọi được qua BoothCmds, thử quét gián tiếp qua Library.Save nếu nó tồn tại
    if not boothData and Library.Save and Library.Save.Get then
        pcall(function()
            local s = Library.Save.Get(player)
            if s and s.Booth then boothData = s.Booth.List end
        end)
    end

    -- Nếu tìm thấy dữ liệu vật phẩm trong Booth
    if boothData then
        -- Đôi khi dữ liệu bọc trong một table con (.List)
        local itemsList = boothData.List or boothData
        
        if type(itemsList) == "table" and next(itemsList) then
            print("\n[BOOTH] Owner: " .. player.Name)
            
            for slotId, details in pairs(itemsList) do
                if details and type(details) == "table" then
                    local itemData = details.Item
                    local price = details.Price or 0
                    local amount = details.Amount or 1
                    
                    local itemName = "Unknown Item"
                    if itemData then
                        pcall(function()
                            itemName = ItemCmds.GetName(itemData)
                        end)
                    end
                    
                    print(string.format("   -> %s (x%d) | Price: %s Gems", itemName, amount, tostring(price)))
                end
            end
        end
    end
end

print("\n--- SCAN COMPLETE ---")
