-- 2. Hàm gửi Discord (Code cốt lõi)
local function sendToDiscord(petName, rarity)
    local HttpService = game:GetService("HttpService")
    
    -- Tạo nội dung tin nhắn Embed
    local data = {
        embeds = {{
            title = "🐣 NEW PET CAUGHT!",
            description = "**Tên Pet:** `" .. tostring(petName) .. "`\n**Độ hiếm:** `" .. tostring(rarity) .. "`",
            color = 5763719, -- Màu xanh lá
            footer = { text = "Auto Script | " .. os.date("%H:%M:%S") }
        }}
    }

    -- Bắt lỗi khi gửi (dùng pcall để không bị crash script)
    local success, err = pcall(function()
        request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)

    if success then
        print("✅ Đã gửi thông báo lên Discord: " .. tostring(petName))
    else
        warn("❌ Gửi thất bại! Lỗi: " .. tostring(err))
        -- Nếu lỗi là "attempt to call a nil value", Executor bạn đang dùng đã chặn hàm request()
    end
end

-- 3. Bắt sự kiện Hatch (Cách an toàn cho mọi game Pet Sim)
print("🟢 Script đang chạy, đang chờ bạn nở trứng...")

-- Dùng RemoteEvent (Cách chính xác nhất)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remote = ReplicatedStorage:WaitForChild("Remotes", 10) 

if remote then
    -- Sự kiện này kích hoạt mỗi lần nở trứng
    remote.HatchEvent.OnClientEvent:Connect(function(petData)
        local name = "Unknown Pet"
        local rarity = "Unknown"

        -- Xử lý dữ liệu game trả về
        if type(petData) == "table" then
            name = petData.Name or petData._id or "Unknown"
            rarity = petData.Rarity or "Common"
        elseif type(petData) == "string" then
            name = petData
        end
        
        -- Gửi webhook
        sendToDiscord(name, rarity)
    end)
    print("✅ Đã tìm thấy Remote HatchEvent, sẵn sàng hoạt động!")
else
    warn("❌ KHÔNG TÌM THẤY REMOTE. Thử dùng cách quan sát Inventory...")
    -- (Dự phòng) Nếu không bắt được remote, thử quan sát inventory
    local Players = game:GetService("Players")
    local inv = Players.LocalPlayer:WaitForChild("PetInventory", 5)
    if inv then
        local oldCount = #inv:GetChildren()
        inv.ChildAdded:Connect(function(newPet)
            task.wait(0.2) -- Chờ game load xong pet
            sendToDiscord(newPet.Name, "Unknown (Inventory)")
        end)
        print("✅ Đã dùng cách dự phòng Inventory!")
    end
end
