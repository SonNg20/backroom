-- ============================
-- HÀM TÌM SERVER MỚI (CỰC MẠNH + ANTI TRÙNG)
-- ============================
local function findNewServer()
    local allServers = {}
    local cursor = ""
    
    -- Quét qua nhiều trang bằng cursor để lấy danh sách server thực tế nhất
    -- Chạy vòng lặp 3-4 lần để tăng độ phủ dữ liệu
    for i = 1, 4 do
        local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?limit=100&cursor=" .. cursor
        local success, result = pcall(function()
            return game:HttpGet(url)
        end)
        
        if success and result then
            local data = HttpService:JSONDecode(result)
            if data and data.data then
                for _, server in ipairs(data.data) do
                    -- Chỉ lấy các server có người chơi và chưa đầy
                    if server.playing and server.maxPlayers and server.playing < server.maxPlayers then
                        table.insert(allServers, server)
                    end
                end
                cursor = data.nextPageCursor or ""
                if cursor == "" then break end
            else
                break
            end
        else
            break
        end
        task.wait(0.1) -- Delay nhỏ để tránh bị rate-limit HTTP
    end
    
    -- Trộn ngẫu nhiên danh sách server thu thập được (Fisher-Yates Shuffle)
    for i = #allServers, 2, -1 do
        local j = math.random(1, i)
        allServers[i], allServers[j] = allServers[j], allServers[i]
    end
    
    -- Ưu tiên 1: Tìm server chưa ghé, có từ 1 đến 5 người (Lý tưởng để quét boss)
    for _, server in ipairs(allServers) do
        if server.id and not getgenv().VisitedServers[server.id] then
            if server.playing >= 1 and server.playing <= 5 then
                return server.id
            end
        end
    end
    
    -- Ưu tiên 2: Nếu hết server lý tưởng, lấy đại server bất kỳ chưa ghé
    for _, server in ipairs(allServers) do
        if server.id and not getgenv().VisitedServers[server.id] then
            return server.id
        end
    end
    
    -- Ưu tiên 3: Nếu đã đi hết sạch các server, reset lại danh sách bộ nhớ và chọn bừa 1 cái
    getgenv().VisitedServers = {}
    if #allServers > 0 then
        return allServers[math.random(1, #allServers)].id
    end
    
    return nil
end

-- ============================
-- HOP SERVER CỰC MẠNH (DÙNG TELEPORT ASYNC)
-- ============================
local function hopServer()
    local targetServerId = findNewServer()
    
    if targetServerId then
        getgenv().VisitedServers[targetServerId] = true
        
        -- Khởi tạo tùy chọn Teleport nâng cao
        local teleportOptions = Instance.new("TeleportOptions")
        teleportOptions.ServerInstanceId = targetServerId
        
        -- Thử thách teleport liên tục bằng vòng lặp nếu thất bại (Max 3 lần)
        for attempt = 1, 3 do
            local success, err = pcall(function()
                TeleportService:TeleportAsync(PLACE_ID, {player}, teleportOptions)
            end)
            
            if success then 
                break 
            else
                warn("Hop server that bai, thu lai sau 2s... Loi: " .. tostring(err))
                task.wait(2)
            end
        end
    else
        -- Cách cứu cánh cuối cùng: Teleport đại vào game (Roblox tự xếp server)
        pcall(function()
            TeleportService:Teleport(PLACE_ID, player)
        end)
    end
end
