-- ============================
-- AUTO JOIN EVENT + TÌM BOSS + GỬI DISCORD + HOP SERVER KHÔNG TRÙNG
-- ============================

getgenv().WebhookURL = ""
getgenv().WebhookUserID = ""

local webhookURL = getgenv().WebhookURL
local DiscordUserID = getgenv().WebhookUserID
local playerName = game.Players.LocalPlayer.Name
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ============================
-- LƯU DANH SÁCH SERVER ĐÃ GHÉ (CHỐNG TRÙNG)
-- ============================
if not getgenv().VisitedServers then
    getgenv().VisitedServers = {}
end

-- ============================
-- HÀM LẤY SERVER MỚI (KHÔNG TRÙNG)
-- ============================
local function getNewServer()
    local placeId = game.PlaceId
    local cursor = ""
    local allServers = {}
    
    -- Lấy 300 server
    for page = 1, 3 do
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?limit=100&sortOrder=Desc"
        if cursor ~= "" then
            url = url .. "&cursor=" .. cursor
        end
        
        local success, result = pcall(function()
            return game:HttpGet(url)
        end)
        
        if success and result then
            local data = HttpService:JSONDecode(result)
            if data.data then
                for _, server in ipairs(data.data) do
                    table.insert(allServers, server)
                end
            end
            cursor = data.nextPageCursor or ""
            if cursor == "" then break end
        else
            break
        end
    end
    
    -- Lọc server: ít người + chưa từng ghé
    local bestServer = nil
    local lowestPlayers = 999
    
    for _, server in ipairs(allServers) do
        local playing = server.playing
        local maxPlayers = server.maxPlayers
        local jobId = server.id
        
        -- Bỏ qua server đã ghé
        if not getgenv().VisitedServers[jobId] then
            if playing >= 1 and playing < maxPlayers and playing < lowestPlayers then
                lowestPlayers = playing
                bestServer = server
            end
        end
    end
    
    -- Nếu không tìm thấy server mới, reset danh sách đã ghé và thử lại
    if not bestServer then
        getgenv().VisitedServers = {}
        for _, server in ipairs(allServers) do
            local playing = server.playing
            local maxPlayers = server.maxPlayers
            if playing >= 1 and playing < maxPlayers and playing < lowestPlayers then
                lowestPlayers = playing
                bestServer = server
            end
        end
    end
    
    return bestServer
end

-- ============================
-- LƯU SERVER HIỆN TẠI VÀO DANH SÁCH ĐÃ GHÉ
-- ============================
getgenv().VisitedServers[game.JobId] = true

-- ============================
-- 1. JOIN EVENT
-- ============================
local libraryFolder = ReplicatedStorage:WaitForChild("Library", 30)
if libraryFolder then
    local ClientFolder = libraryFolder:WaitForChild("Client", 15)
    local InstancingCmds = require(ClientFolder:WaitForChild("InstancingCmds"))
    local FFlags = require(ClientFolder:WaitForChild("FFlags"))
    
    local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
    if joinTarget then
        InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
    end
end

task.wait(10)

-- ============================
-- 2. ĐẾM BOSS
-- ============================
local Breakables = workspace.__THINGS.Breakables
local bosses = 0

for _, breakable in ipairs(Breakables:GetChildren()) do
    if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
        bosses = bosses + 1
    end
end

-- ============================
-- 3. XỬ LÝ KẾT QUẢ
-- ============================
if bosses >= 3 then
    local serverJobId = game.JobId
    local placeId = game.PlaceId
    local playerCount = #game.Players:GetPlayers()
    
    local description = "🎉 **" .. playerName .. "** đã tìm thấy server có **" .. bosses .. "** Boss!\n"
    description = description .. "Server JobId: `" .. serverJobId .. "`\n"
    description = description .. "Place ID: `" .. placeId .. "`\n"
    description = description .. "Số người chơi: " .. playerCount .. "\n"
    description = description .. "Số boss: **" .. bosses .. "**\n"
    description = description .. "Đã hop qua: " .. #getgenv().VisitedServers .. " server"
    
    if webhookURL ~= "" then
        pcall(function()
            syn.request({
                Url = webhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    content = DiscordUserID ~= "" and "<@" .. DiscordUserID .. ">" or "",
                    embeds = {{
                        title = "🔥 TIM THAY SERVER NHIEU BOSS",
                        description = description,
                        color = 16711680,
                        footer = {text = "Pet Simulator 99 - Boss Scanner"},
                        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
                    }}
                })
            })
        end)
    end
else
    local newServer = getNewServer()
    
    if newServer then
        getgenv().VisitedServers[newServer.id] = true
        pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, newServer.id, game.Players.LocalPlayer)
        end)
    else
        pcall(function()
            TeleportService:Teleport(game.PlaceId)
        end)
    end
end
