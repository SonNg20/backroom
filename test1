-- ============================
-- AUTO COLLECT ORB - SOCCER EVENT (FIX)
-- ============================

if not game:IsLoaded() then game.Loaded:Wait() end

local ReplicatedStorage = game:GetService("ReplicatedStorage")

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            local yeetOrbs = workspace.__THINGS.__INSTANCE_CONTAINER.Active.SoccerEvent.ClientModule.YeetOrbs
            
            for _, orb in ipairs(yeetOrbs:GetChildren()) do
                if orb:IsA("BasePart") and orb.Name ~= "" then
                    local args = {
                        [1] = "SoccerEvent",
                        [2] = "ClaimOrb",
                        [3] = orb
                    }
                    
                    ReplicatedStorage.Network.Instancing_FireCustomFromClient:FireServer(unpack(args))
                end
            end
        end)
    end
end)
