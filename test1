-- 1. Link Webhook của bạn
local WebhookURL = "https://discord.com/api/webhooks/1516774421787054262/kpEu6j9Iz_Zi01XN_mRvQRY-pvIkygxAiZypxCcdIRfWqpEV12BDG6vtgddMB_Nr1_os"

-- 2. Hàm gửi thông báo Discord
local function sendToDiscord(petName, rarity)
    local HttpService = game:GetService("HttpService")
    
    local data = {
        embeds = {{
            title = "🐣 NEW PET CAUGHT!",
            description = "**Pet:** `" .. tostring(petName) .. "`\n**Rarity:** `" .. tostring(rarity) .. "`",
            color = 5763719,
            footer = { text = "Inventory Monitor | " .. os.date("%H:%M:%S") }
        }}
    }

    -- Dùng pcall để bắt lỗi nếu không gửi được
    local success, err = pcall(function()
        request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)

    if success then
        print("✅ Đã gửi: " .. tostring(petName))
    else
        warn("❌ Gửi thất bại (Lỗi Request): " .. tostring(err))
    end
end

-- 3. BẮT ĐẦU THEO DÕI INVENTORY
print("🟢 Đang chờ game tải Inventory...")

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

-- Chờ cho Inventory của game xuất hiện
local inventoryFolder = localPlayer:WaitForChild("PetInventory", 15)

if inventoryFolder then
    print("✅ Đã tìm thấy thư mục PetInventory!")
    
    -- Biến để lưu số lượng pet hiện tại
    local currentPetCount = #inventoryFolder:GetChildren()

    -- Tạo vòng lặp kiểm tra (Check mỗi 1.5 giây 1 lần)
    spawn(function()
        while task.wait(1.5) do
            -- Kiểm tra xem Inventory có sự thay đổi số lượng không
            local newPetCount = #inventoryFolder:GetChildren()
            
            if newPetCount > currentPetCount then
                -- Đã có pet mới!
                local newPet = inventoryFolder:GetChildren()[newPetCount]
                local petName = "Unknown Pet"
                local petRarity = "Unknown"

                if newPet then
                    petName = newPet.Name
                    
                    -- Thử lấy độ hiếm (Rarity) nếu game có lưu trong thuộc tính của Pet
                    local successGet, rarityVal = pcall(function()
                        return newPet:FindFirstChild("Rarity") and newPet.Rarity.Value or "Unknown"
                    end)
                    
                    if successGet and rarityVal then
                        petRarity = rarityVal
                    else
                        -- Nếu không lấy được rarity, thử lấy bằng tên của Model
                        local successFind, foundRarity = pcall(function()
                            return newPet:FindFirstChild("Configuration") and newPet.Configuration.Rarity.Value or "Unknown"
                        end)
                        if successFind then petRarity = foundRarity end
                    end

                    -- Gửi thông báo
                    sendToDiscord(petName, petRarity)
                end

                -- Cập nhật lại số lượng để lần sau so sánh tiếp
                currentPetCount = newPetCount
            end
        end
    end)
    
    print("🟢 Bắt đầu theo dõi! Cứ nở trứng là sẽ báo.")
else
    warn("❌ LỖI NẶNG: Không tìm thấy PetInventory. Bạn đang chơi Pet Simulator 99 đúng không?")
end
