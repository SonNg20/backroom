-- ============================
-- TRÌNH TỰ 3: TIẾN HÀNH FARM LOOP (BẮT ĐẦU VÒNG LẶP CHÍNH)
-- ============================
local idx = 1
local numRooms = #bossRooms 

while true do
    local allRoomsOnCooldown = true
    for i = 1, numRooms do
        if not isChestOnCooldown(bossRooms[i]) then
            allRoomsOnCooldown = false
            break
        end
    end

    if allRoomsOnCooldown then
        updateStatusUI("Tat ca Boss dang hoi -> Dung quet & dung im cho tai cho...")
        while true do
            local anyRoomReady = false
            for i = 1, numRooms do
                if not isChestOnCooldown(bossRooms[i]) then
                    anyRoomReady = true
                    idx = i 
                    break
                end
            end
            if anyRoomReady then break end
            task_wait(1) 
        end
    end

    local entry = bossRooms[idx]
    local room = entry.room
    local onCooldown, bz = isChestOnCooldown(entry)

    if onCooldown then
        idx = idx % numRooms + 1 
        task_wait(0.2)
        continue
    end

    updateStatusUI(string_format("Boss %d/%d: TELE va DANH BOSS", idx, numRooms))

    for i = 1, 3 do
        safeTeleport(entry.pos)
        task_wait(1)
    end

    local _, bzFresh = isChestOnCooldown(entry)
    bz = bzFresh or bz

    if room:IsA("Model") and not entry.unlocked and isLocked(room) then
        updateStatusUI(string_format("Boss %d/%d: DANG MO KHOA...", idx, numRooms))
        local unlockStart = tick()
        while isLocked(room) do
            unlockRoom(room)
            task_wait(1)
            if tick() - unlockStart > 30 then
                break
            end
        end
        entry.unlocked = true
    end

    local _, bzFinal = isChestOnCooldown(entry)
    bz = bzFinal or bz
    
    local corners = getCorners(room, bz, entry.pos)
    local miniSpots = {corners[2], corners[3], corners[4], corners[5]}

    local pendingChests = {}
    local processing = false

    local function nearestSpotIndex(pos)
        local bestIdx, bestDist = nil, math.huge
        for i = 1, 4 do
            local spot = miniSpots[i]
            if spot then
                local d = (spot - pos).Magnitude
                if d < bestDist then
                    bestDist = d
                    bestIdx = i
                end
            end
        end
        return bestIdx, bestDist
    end

    local listenerConn = breakablesContainer.ChildAdded:Connect(function(inst)
        task_defer(function()
            if not isBreakableInstance(inst) then return end
            local part = inst:IsA("BasePart") and inst or inst:FindFirstChildWhichIsA("BasePart", true)
            if not part then return end
            local idx2, dist = nearestSpotIndex(part.Position)
            if idx2 and dist <= 15 then
                table_insert(pendingChests, {pos = miniSpots[idx2], inst = inst})
            end
        end)
    end)

    farmingThisRoom = true

    task_spawn(function()
        while farmingThisRoom do
            if #pendingChests > 0 and not processing then
                processing = true
                local chestEntry = table_remove(pendingChests, 1)

                safeTeleport(chestEntry.pos)
                updateStatusUI(string_format("Boss %d/%d: Danh Mini Chest", idx, numRooms))

                while chestEntry.inst and chestEntry.inst.Parent do
                    task_wait(0.2)
                end

                processing = false
            else
                task_wait(0.1)
            end
        end
    end)

    while true do
        local cooldown = isChestOnCooldown(entry)
        if cooldown then
            updateStatusUI(string_format("Boss %d/%d: Da pha! Chuyen Boss...", idx, numRooms))
            break
        end

        if #pendingChests == 0 and not processing then
            for run = 1, 3 do
                if isChestOnCooldown(entry) or #pendingChests > 0 or processing then break end
                safeTeleport(entry.pos)
                updateStatusUI(string_format("Boss %d/%d: Dang danh Boss (Tele %d/3)", idx, numRooms, run))
                task_wait(0.5)
            end
        end
        task_wait(0.1)
    end

    farmingThisRoom = false
    listenerConn:Disconnect()

    idx = idx % numRooms + 1
    task_wait(0.5)
end
