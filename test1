-- 2. Hàm gửi thông báo tổng quát (Hỗ trợ mọi Executor)
local function sendToDiscord(petName, rarity)
    local HttpService = game:GetService("HttpService")
    
    local payload = {
        content = "**🎉 New Pet Hatched! 🎉**",
        embeds = {{
            title = "Pet Simulator 99",
            description = "**Pet:** `" .. tostring(petName) .. "`\n**Rarity:** `" .. tostring(rarity) .. "`",
            color = 5763719,
            footer = { text = "Auto Noti | " .. os.date("%H:%M:%S") }
        }}
    }

    local jsonData = HttpService:JSONEncode(payload)

    -- Thử tất cả các cách gửi có thể (Tự động chọn cái nào chạy được)
    local sent = false
    if not sent then
        local s, e = pcall(function()
            request({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = jsonData})
        end)
        if s then sent = true else print("❌ Cách 1 (request) thất bại.") end
    end
    
    if not sent then
        local s, e = pcall(function()
            syn.request({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = jsonData})
        end)
        if s then sent = true else print("❌ Cách 2 (syn.request) thất bại.") end
    end
    
    if not sent then
        local s, e = pcall(function()
            http_request({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = jsonData})
        end)
        if s then sent = true else print("❌ Cách 3 (http_request) thất bại.") end
    end

    if sent then
        print("✅ Gửi Discord thành công: " .. petName)
    else
        warn("❌ THẤT BẠI HOÀN TOÀN. Executor bạn dùng không hỗ trợ gửi Webhook!") 
    end
end

-- 3. Bắt sự kiện nở trứng chuẩn PS99
print("🟢 Đang tìm PetInventory của PS99...")
local Players = game:GetService("Players")
local inv = Players.LocalPlayer:WaitForChild("PetInventory", 10)

if inv then
    print("✅ Đã tìm thấy Inventory! Bắt đầu theo dõi mỗi 2 giây...")
    local count = #inv:GetChildren()
    
    while task.wait(2) do -- Cứ 2 giây check 1 lần
        local newCount = #inv:GetChildren()
        if newCount > count then
            local newPet = inv:GetChildren()[newCount]
            if newPet then
                sendToDiscord(newPet.Name, "Unknown (Inventory)")
                count = newCount -- Cập nhật số lượng mới
            end
        end
    end
else
    warn("❌ Không tìm thấy Inventory.")
end
