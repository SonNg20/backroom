-- DEBUG - TÌM REMOTE VÀ YEET ORB
-- ============================

if not game:IsLoaded() then game.Loaded:Wait() end

local ReplicatedStorage = game:GetService("ReplicatedStorage")

print("=== DEBUG SOCCER EVENT ===")

-- 1. Tìm YeetOrbs folder
local soccerEvent = workspace.__THINGS.__INSTANCE_CONTAINER.Active:FindFirstChild("SoccerEvent")
if soccerEvent then
    print("✅ SoccerEvent found!")
    
    local clientModule = soccerEvent:FindFirstChild("ClientModule")
    if clientModule then
        print("✅ ClientModule found!")
        print("Children of ClientModule:")
        for _, child in ipairs(clientModule:GetChildren()) do
            print("  - " .. child.Name .. " [" .. child.ClassName .. "]")
        end
        
        local yeetOrbs = clientModule:FindFirstChild("YeetOrbs")
        if yeetOrbs then
            print("✅ YeetOrbs found!")
            print("Number of orbs: " .. #yeetOrbs:GetChildren())
            
            -- In 3 orb đầu tiên
            local count = 0
            for _, orb in ipairs(yeetOrbs:GetChildren()) do
                if count < 3 then
                    print("  Orb: " .. orb.Name .. " [" .. orb.ClassName .. "]")
                    count = count + 1
                end
            end
        else
            print("❌ YeetOrbs NOT found!")
        end
    else
        print("❌ ClientModule NOT found!")
    end
else
    print("❌ SoccerEvent NOT found!")
end

-- 2. Tìm Remote
print("\n=== TÌM REMOTE ===")
local network = ReplicatedStorage:FindFirstChild("Network")
if network then
    local instancingFire = network:FindFirstChild("Instancing_FireCustomFromClient")
    if instancingFire then
        print("✅ Instancing_FireCustomFromClient found!")
    end
end

-- 3. Thử lấy InstancingCmds
print("\n=== INSTANCINGCMDS ===")
local libraryFolder = ReplicatedStorage:FindFirstChild("Library")
if libraryFolder then
    local clientFolder = libraryFolder:FindFirstChild("Client")
    if clientFolder then
        local instancingCmds = clientFolder:FindFirstChild("InstancingCmds")
        if instancingCmds then
            print("✅ InstancingCmds module found!")
            local cmds = require(instancingCmds)
            if cmds then
                print("✅ Require successful!")
                -- In các function có sẵn
                print("Functions:")
                for k, v in pairs(cmds) do
                    print("  - " .. k .. " [" .. type(v) .. "]")
                end
            end
        end
    end
end
