-- ============================
-- AUTO JOIN EVENT + TÌM BOSS + GỬI DISCORD + HOP SERVER ÍT NGƯỜI
-- ============================

getgenv().WebhookURL = ""
getgenv().WebhookUserID = ""

local webhookURL = getgenv().WebhookURL
local DiscordUserID = getgenv().WebhookUserID
local playerName = game.Players.LocalPlayer.Name
local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- ============================
-- HÀM TÌM SERVER ÍT NGƯỜI
-- ============================
local function findSmallServer()
    local placeId = game.PlaceId
    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?limit=100&sortOrder=Asc")
    end)
    
    if success and result then
        local data = HttpService:JSONDecode(result)
        local servers = data.data
        
        -- Tìm server ít người nhất (1-3 người)
        local bestServer = nil
        local lowestPlayers = 999
        
        for _, server in ipairs(servers) do
            local playing = server.playing
            local maxPlayers = server.maxPlayers
            
            -- Chỉ chọn server có 1-3 người chơi
            if playing >= 1 and playing <= 3 and playing < lowestPlayers then
                lowestPlayers = playing
                bestServer = server
            end
        end
        
        if bestServer then
            return bestServer.id, lowestPlayers
        end
    end
    
    return nil, nil
end

-- ============================
-- 1. JOIN EVENT
-- ============================
local libraryFolder = ReplicatedStorage:WaitForChild("Library", 30)
if libraryFolder then
    local ClientFolder = libraryFolder:WaitForChild("Client", 15)
    local InstancingCmds = require(ClientFolder:WaitForChild("InstancingCmds"))
    local FFlags = require(ClientFolder:WaitForChild("FFlags"))
    
    local joinTarget = FFlags.Get(FFlags.Keys.SideJoinEventTarget)
    if joinTarget then
        InstancingCmds.Enter(joinTarget, nil, true, "You are joining the minigame!")
    end
end

task.wait(10)

-- ============================
-- 2. ĐẾM BOSS
-- ============================
local Breakables = workspace.__THINGS.Breakables
local bosses = 0

for _, breakable in ipairs(Breakables:GetChildren()) do
    if breakable:IsA("Model") and breakable:GetAttribute("BreakableID") == "Daydream Mimic Boss2" then
        bosses = bosses + 1
    end
end

-- ============================
-- 3. XỬ LÝ KẾT QUẢ
-- ============================
if bosses >= 3 then
    local serverJobId = game.JobId
    local placeId = game.PlaceId
    local playerCount = #game.Players:GetPlayers()
    
    local description = "🎉 **" .. playerName .. "** đã tìm thấy server có **" .. bosses .. "** Boss!\n"
    description = description .. "Server JobId: `" .. serverJobId .. "`\n"
    description = description .. "Place ID: `" .. placeId .. "`\n"
    description = description .. "Số người chơi: " .. playerCount .. "\n"
    description = description .. "Số boss: **" .. bosses .. "**"
    
    if webhookURL ~= "" then
        pcall(function()
            syn.request({
                Url = webhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    content = DiscordUserID ~= "" and "<@" .. DiscordUserID .. ">" or "",
                    embeds = {{
                        title = "🔥 TIM THAY SERVER NHIEU BOSS",
                        description = description,
                        color = 16711680,
                        footer = {text = "Pet Simulator 99 - Boss Scanner"},
                        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
                    }}
                })
            })
        end)
    end
else
    -- Tìm server ít người nhất
    local bestJobId, playerCount = findSmallServer()
    
    if bestJobId then
        -- Teleport đến server ít người
        pcall(function()
            TeleportService:TeleportToPlaceInstance(game.PlaceId, bestJobId, game.Players.LocalPlayer)
        end)
    else
        -- Fallback: Teleport thường
        pcall(function()
            TeleportService:Teleport(game.PlaceId, game.Players.LocalPlayer)
        end)
    end
end
